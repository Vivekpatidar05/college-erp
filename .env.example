# ─── DSVV ERP — Local Dev Environment ───────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to Git.

# Flask secret key (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-very-long-random-secret-key-here

# MongoDB Atlas connection string
# Get from: Atlas Dashboard → Connect → Drivers → Python
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (created automatically on first run)
DB_NAME=dsvv_erp

# Flask settings (for local dev only)
FLASK_ENV=development
FLASK_DEBUG=1
